<script>
	import WaveSurfer from 'wavesurfer.js';
	import SpectrogramPlugin from 'wavesurfer.js/dist/plugins/spectrogram.esm.js';

	const formatTime = (seconds: number) => {
		if (!Number.isFinite(seconds)) return '0:00';

		const minutes = Math.floor(seconds / 60);
		const remainingSeconds = Math.floor(seconds % 60);

		return `${minutes}:${remainingSeconds.toString().padStart(2, '0')}`;
	};

	document.querySelectorAll<HTMLElement>('.audio-spectrum').forEach((player) => {
		if (player.dataset.ready === 'true') return;

		const url = player.dataset.src;
		const title = player.dataset.title || 'Audio';
		const waveform = player.querySelector<HTMLElement>('[data-waveform]');
		const spectrogram = player.querySelector<HTMLElement>('[data-spectrogram]');
		const playButton = player.querySelector<HTMLButtonElement>('[data-play]');
		const currentTime = player.querySelector<HTMLElement>('[data-current-time]');
		const duration = player.querySelector<HTMLElement>('[data-duration]');

		if (!url || !waveform || !spectrogram || !playButton || !currentTime || !duration) return;

		player.dataset.ready = 'true';
		playButton.disabled = true;
		playButton.setAttribute('aria-label', `Reproducir ${title}`);

		const wavesurfer = WaveSurfer.create({
			container: waveform,
			url,
			height: 28,
			barWidth: 2,
			barGap: 2,
			barRadius: 3,
			cursorWidth: 0,
			normalize: true,
			waveColor: '#94a3b8',
			progressColor: '#2563eb',
			dragToSeek: true,
			plugins: [
				SpectrogramPlugin.create({
					container: spectrogram,
					height: 150,
					labels: true,
					labelsBackground: '#0f172a',
					labelsColor: '#e2e8f0',
					labelsHzColor: '#94a3b8',
					scale: 'mel',
					fftSamples: 1024,
					frequencyMin: 20,
					frequencyMax: 12000,
					gainDB: 22,
					rangeDB: 80,
					colorMap: 'roseus',
				}),
			],
		});

		wavesurfer.on('ready', () => {
			playButton.disabled = false;
			duration.textContent = formatTime(wavesurfer.getDuration());
		});

		wavesurfer.on('timeupdate', (time) => {
			currentTime.textContent = formatTime(time);
		});

		wavesurfer.on('play', () => {
			playButton.textContent = 'Pausar';
			playButton.setAttribute('aria-label', `Pausar ${title}`);
			player.dataset.playing = 'true';
		});

		wavesurfer.on('pause', () => {
			playButton.textContent = 'Reproducir';
			playButton.setAttribute('aria-label', `Reproducir ${title}`);
			player.dataset.playing = 'false';
		});

		wavesurfer.on('finish', () => {
			playButton.textContent = 'Reproducir';
			playButton.setAttribute('aria-label', `Reproducir ${title}`);
			player.dataset.playing = 'false';
		});

		playButton.addEventListener('click', () => {
			void wavesurfer.playPause();
		});
	});
</script>

