---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
}

const { prevPost, nextPost } = Astro.props;
---

{(prevPost || nextPost) && (
	<nav class="post-navigation">
		<div class="nav-grid">
			{prevPost ? (
				<a href={`/blog/${prevPost.id}/`} class="nav-link nav-prev">
					<span class="nav-label">← Anterior</span>
					<span class="nav-title">{prevPost.data.title}</span>
					<span class="nav-date"><FormattedDate date={prevPost.data.pubDate} /></span>
				</a>
			) : (
				<div class="nav-link nav-prev nav-empty"></div>
			)}
			
			{nextPost ? (
				<a href={`/blog/${nextPost.id}/`} class="nav-link nav-next">
					<span class="nav-label">Siguiente →</span>
					<span class="nav-title">{nextPost.data.title}</span>
					<span class="nav-date"><FormattedDate date={nextPost.data.pubDate} /></span>
				</a>
			) : (
				<div class="nav-link nav-next nav-empty"></div>
			)}
		</div>
	</nav>
)}

<style>
	.post-navigation {
		margin-top: 3rem;
		margin-bottom: 2rem;
		border-top: 1px solid rgba(var(--gray), 0.3);
		padding-top: 2rem;
	}

	.nav-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
	}

	.nav-link {
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		border: 1px solid rgba(var(--gray), 0.2);
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		transition: all 0.3s ease;
	}

	.nav-link:hover {
		border-color: rgba(var(--black), 0.3);
		background-color: rgba(var(--gray-light), 0.5);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
	}

	.nav-empty {
		visibility: hidden;
	}

	.nav-label {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		font-weight: 500;
		margin-bottom: 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.nav-title {
		font-size: 1rem;
		font-weight: 600;
		margin-bottom: 0.5rem;
		line-height: 1.3;
		color: rgb(var(--black));
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.nav-date {
		font-size: 0.8rem;
		color: rgb(var(--gray));
	}

	.nav-prev {
		text-align: left;
	}

	.nav-next {
		text-align: right;
	}

	@media (max-width: 720px) {
		.nav-grid {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.nav-link {
			padding: 1rem;
		}

		.nav-label {
			font-size: 0.75rem;
		}

		.nav-title {
			font-size: 0.9rem;
		}
	}
</style>
