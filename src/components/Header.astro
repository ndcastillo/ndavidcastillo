---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import SearchBar from './SearchBar.astro';
---

<header>
	<nav>
		<h2><a class="site-title" href="/">{SITE_TITLE}</a></h2>
		<div class="nav-right">
			<div class="internal-links">
				<HeaderLink href="/blog">Posts</HeaderLink>
				<HeaderLink href="/about">Acerca de mi</HeaderLink>
			</div>
			<SearchBar />
		</div>
		<!-- SearchBar para móvil (solo modal, sin botón) -->
		<div class="mobile-search-modal">
			<SearchBar />
		</div>
		<button class="mobile-menu-toggle" aria-label="Toggle mobile menu">
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
		</button>
	</nav>
	<div class="mobile-menu">
		<div class="mobile-internal-links">
			<HeaderLink href="/blog">Posts</HeaderLink>
			<HeaderLink href="/about">Acerca de mi</HeaderLink>
		</div>
		<div class="mobile-search">
			<button class="search-trigger" aria-label="Buscar artículos" title="Buscar">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"></circle>
					<path d="m21 21-4.3-4.3"></path>
        </svg>
        Buscar Articulo
			</button>
		</div>
	</div>
</header>

<script>
	// Mobile menu toggle functionality
	document.addEventListener('DOMContentLoaded', function() {
		const mobileMenuToggle = document.querySelector('.mobile-menu-toggle');
		const mobileMenu = document.querySelector('.mobile-menu');
		
		if (mobileMenuToggle && mobileMenu) {
			mobileMenuToggle.addEventListener('click', function() {
				mobileMenuToggle.classList.toggle('active');
				mobileMenu.classList.toggle('active');
			});
			
			// Close mobile menu when clicking on a link
			const mobileLinks = mobileMenu.querySelectorAll('a');
			mobileLinks.forEach(link => {
				link.addEventListener('click', function() {
					mobileMenuToggle.classList.remove('active');
					mobileMenu.classList.remove('active');
				});
			});
		}
		
		// Close mobile menu when search modal opens
		document.addEventListener('DOMContentLoaded', function() {
			const searchModal = document.getElementById('searchModal');
			if (searchModal) {
				const observer = new MutationObserver(function(mutations) {
					mutations.forEach(function(mutation) {
						if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
							if (searchModal.classList.contains('active')) {
								if (mobileMenuToggle && mobileMenu) {
									mobileMenuToggle.classList.remove('active');
									mobileMenu.classList.remove('active');
								}
							}
						}
					});
				});
				
				observer.observe(searchModal, { attributes: true });
			}
		});
	});
</script>

<style>
  header {
    max-width:960px;
		margin: 10px auto;
		padding: 0 1em;
    border-radius: 100px;

    h2{
      font-style: italic;
    }
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	nav a {
		padding: 10px;
		color: var(--black);
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
	}
	.social-links,
	.social-links a {
		display: flex;
	}
  .internal-links{
    font-size:1rem;
  }
	
	/* Mobile menu styles */
	.mobile-menu-toggle {
		display: none;
		flex-direction: column;
		background: none;
		border: none;
		cursor: pointer;
		padding: 8px;
		gap: 4px;
	}
	
	.hamburger-line {
		width: 24px;
		height: 3px;
		background-color: rgb(var(--black));
		border-radius: 2px;
		transition: all 0.3s ease;
	}
	
	.mobile-menu {
		display: none;
		flex-direction: column;
		gap: 1rem;
		padding: 1rem;
		border-top: 1px solid rgba(0, 0, 0, 0.1);
		margin-top: 1rem;
	}
	
	.mobile-internal-links {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	
	.mobile-search {
		width: 100%;
		display: flex;
    gap:10px;
	}
	
	.mobile-search .search-trigger {
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: rgb(var(--gray-dark));
		border-radius: 8px;
		transition: all 0.2s ease;
	}
	
	.mobile-search .search-trigger:hover {
		background: rgba(var(--gray-light), 0.5);
		color: rgb(var(--black));
	}
	
	.mobile-search-modal {
		display: none;
	}
	
	.mobile-search-modal .search-trigger {
		display: none;
	}
	
	/* Show mobile menu when active */
	.mobile-menu.active {
		display: flex;
	}
	
	/* Hamburger animation when active */
	.mobile-menu-toggle.active .hamburger-line:nth-child(1) {
		transform: rotate(45deg) translate(3px, 7px);
	}
	
	.mobile-menu-toggle.active .hamburger-line:nth-child(2) {
		opacity: 0;
		transform: scale(0);
	}
	
	.mobile-menu-toggle.active .hamburger-line:nth-child(3) {
		transform: rotate(-45deg) translate(4px, -7px);
	}

	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		
		.nav-right {
			display: none;
		}
		
		.mobile-menu-toggle {
			display: flex;
		}
	}
</style>
