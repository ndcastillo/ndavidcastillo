        </svg>
        Buscar Articulo
			</button>
		</div> -->
	</div>
</header>

<script>
	// Theme toggle functionality
	(function() {
		function getThemePreference() {
			const stored = localStorage.getItem('theme');
			if (stored) return stored;
			return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
		}

		function setTheme(theme) {
			document.documentElement.setAttribute('data-theme', theme);
			localStorage.setItem('theme', theme);
		}

		// Apply stored theme immediately
		setTheme(getThemePreference());

		document.addEventListener('DOMContentLoaded', function() {
			// Handle all theme toggle buttons
			document.querySelectorAll('.theme-toggle').forEach(function(btn) {
				btn.addEventListener('click', function() {
					const current = document.documentElement.getAttribute('data-theme') || 'light';
					setTheme(current === 'dark' ? 'light' : 'dark');
				});
			});
		});

		// Listen for OS theme changes (when no manual preference)
		window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
			if (!localStorage.getItem('theme')) {
				setTheme(e.matches ? 'dark' : 'light');
			}
		});
	})();
</script>

<script>
	// Mobile menu toggle functionality
	document.addEventListener('DOMContentLoaded', function() {
		const mobileMenuToggle = document.querySelector('.mobile-menu-toggle');
		const mobileMenu = document.querySelector('.mobile-menu');
		
		if (mobileMenuToggle && mobileMenu) {
			mobileMenuToggle.addEventListener('click', function() {
				mobileMenuToggle.classList.toggle('active');
				mobileMenu.classList.toggle('active');
			});
			
			// Close mobile menu when clicking on a link
			const mobileLinks = mobileMenu.querySelectorAll('a');
			mobileLinks.forEach(link => {
				link.addEventListener('click', function() {
					mobileMenuToggle.classList.remove('active');
					mobileMenu.classList.remove('active');
				});
			});
		}
		
		// Close mobile menu when search modal opens
		document.addEventListener('DOMContentLoaded', function() {
			const searchModal = document.getElementById('searchModal');
			if (searchModal) {
				const observer = new MutationObserver(function(mutations) {
					mutations.forEach(function(mutation) {
						if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
							if (searchModal.classList.contains('active')) {
								if (mobileMenuToggle && mobileMenu) {
									mobileMenuToggle.classList.remove('active');
									mobileMenu.classList.remove('active');
								}
							}
						}
					});
				});
				
				observer.observe(searchModal, { attributes: true });
			}
		});
	});
</script>

<style>
  header {
    max-width:960px;
		margin: 10px auto;
		padding: 0 1em;
    border-radius: 100px;

    h2{
      font-style: italic;
    }
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	nav a {
		padding: 10px;
		color: var(--black);
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
	}
	.social-links,
	.social-links a {
		display: flex;
	}
  .internal-links{
    font-size:1rem;
  }

	/* Theme toggle */
	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 8px;
		color: rgb(var(--gray-dark));
		border-radius: 8px;
		transition: all 0.2s ease;
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}
	.theme-toggle:hover {
		background: rgba(var(--gray-light), 0.5);
		color: rgb(var(--black));
	}
	/* Light mode: show moon, hide sun */
	:root:not([data-theme="dark"]) .icon-moon { display: block; }
	:root:not([data-theme="dark"]) .icon-sun { display: none; }
	/* Dark mode: show sun, hide moon */
	[data-theme="dark"] .icon-sun { display: block; }
	[data-theme="dark"] .icon-moon { display: none; }

	.mobile-theme-toggle {
		display: none;
		font-size: 0.95rem;
	}
	
	/* Mobile menu styles */
	.mobile-menu-toggle {
		display: none;
		flex-direction: column;
		background: none;
		border: none;
		cursor: pointer;
		padding: 8px;
		gap: 4px;
	}
	
	.hamburger-line {
		width: 24px;
		height: 3px;
		background-color: rgb(var(--black));
		border-radius: 2px;
		transition: all 0.3s ease;
	}
	
	.mobile-menu {
		display: none;
		flex-direction: column;
		gap: 1rem;
		padding: 1rem;
		border-top: 1px solid rgb(var(--gray-light));
		margin-top: 1rem;
	}
	
	.mobile-internal-links {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	
	.mobile-search {
		width: 100%;
		display: flex;
    gap:10px;
	}
	
	.mobile-search .search-trigger {
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: rgb(var(--gray-dark));
		border-radius: 8px;
		transition: all 0.2s ease;
	}
	
	.mobile-search .search-trigger:hover {
		background: rgba(var(--gray-light), 0.5);
		color: rgb(var(--black));
	}
	
	.mobile-search-modal {
		display: none;
	}
	
	.mobile-search-modal .search-trigger {
		display: none;
	}
	
	/* Show mobile menu when active */
	.mobile-menu.active {
		display: flex;
	}
	
	/* Hamburger animation when active */
	.mobile-menu-toggle.active .hamburger-line:nth-child(1) {
		transform: rotate(45deg) translate(3px, 7px);
	}
	
	.mobile-menu-toggle.active .hamburger-line:nth-child(2) {
		opacity: 0;
		transform: scale(0);
	}
	
	.mobile-menu-toggle.active .hamburger-line:nth-child(3) {
		transform: rotate(-45deg) translate(4px, -7px);
	}

	@media (max-width: 720px) {
		.social-links {
			display: none;
		}

		.nav-right {
			display: none;
		}

		.mobile-menu-toggle {
			display: flex;
		}

		.mobile-theme-toggle {
			display: flex;
		}
	}
</style>
