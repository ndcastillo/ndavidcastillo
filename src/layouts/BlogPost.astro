---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_URL } from '../consts';
import {readingTime} from '../utils/readingTime';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string, body?: string };

const { title, description, pubDate, updatedDate, heroImage, slug, body, tags } = Astro.props;

// Calcular el tiempo de lectura
const readTime = body ? readingTime(body, "es") : null;

// Obtener el slug del URL si no se pasa como prop
const postSlug = slug || Astro.url.pathname.split('/').filter(Boolean).pop();

---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<meta name="author" content={SITE_AUTHOR} />
		<meta name="robots" content="index, follow" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"datePublished": pubDate.toISOString(),
			...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
			"inLanguage": "es",
			...(tags ? { "keywords": tags.join(", ") } : {}),
			...(body ? { "wordCount": body.split(/\s+/).length } : {}),
			"author": {
				"@type": "Person",
				"name": SITE_AUTHOR,
				"url": SITE_URL
			},
			"publisher": {
				"@type": "Person",
				"name": SITE_AUTHOR,
				"url": SITE_URL
			},
			"mainEntityOfPage": {
				"@type": "WebPage",
				"@id": `${SITE_URL}/blog/${postSlug}/`
			}
		})} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				overflow-x: hidden;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 100%;
				max-width: 720px;
				margin: auto;
				padding: 1em;
				box-sizing: border-box;
				color: rgb(var(--gray-dark));
			}
			.title {
        margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.edit-button {
				display: inline-flex;
				align-items: center;
        gap: 5px;
        justify-content:flex-end;
				color: rgb(var(--gray-dark));
				font-size: 0.9rem;
				font-weight: 500;
				transition: all 0.2s ease;
        // margin-top: 1rem;
			}
			.edit-button:hover {
				background: rgba(0, 0, 0, 0.08);
				border-color: rgba(0, 0, 0, 0.2);
				color: rgb(var(--black));
			}
			.edit-button svg {
				flex-shrink: 0;
			}
      article{


li{
  /* padding: 10px 0; */
  line-height: 1.5;
}
      }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{readTime && <span> · {readTime}</span>}
							{
								updatedDate && (
									<div class="last-updated-on">
										Última modificación el <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
          <hr/>
        <p>
        { tags && tags.map((tag)=>(
        <span> #{tag},</span>
        )) }
        </p>
					<a 
						href={`https://github.com/ndcastillo/ndavidcastillo/blob/main/src/content/blog/${postSlug}.md`}
						class="edit-button"
						target="_blank"
						rel="noopener noreferrer"
						title="Editar en GitHub"
					>
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
							<path d="m18.5 2.5 2 2L13 12l-4 1 1-4 7.5-7.5z"></path>
						</svg>
						Editar en GitHub
					</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
