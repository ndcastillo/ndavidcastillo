---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_URL } from '../consts';
import {readingTime} from '../utils/readingTime';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string, body?: string };

const { title, description, pubDate, updatedDate, heroImage, slug, body, tags } = Astro.props;

// Calcular el tiempo de lectura
const readTime = body ? readingTime(body, "es") : null;

// Obtener el slug del URL si no se pasa como prop
const postSlug = slug || Astro.url.pathname.split('/').filter(Boolean).pop();

---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<meta name="author" content={SITE_AUTHOR} />
		<meta name="robots" content="index, follow" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"datePublished": pubDate.toISOString(),
			...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
			"inLanguage": "es",
			...(tags ? { "keywords": tags.join(", ") } : {}),
			...(body ? { "wordCount": body.split(/\s+/).length } : {}),
			"author": {
				"@type": "Person",
				"name": SITE_AUTHOR,
				"url": SITE_URL
			},
			"publisher": {
				"@type": "Person",
				"name": SITE_AUTHOR,
				"url": SITE_URL
			},
			"mainEntityOfPage": {
				"@type": "WebPage",
				"@id": `${SITE_URL}/blog/${postSlug}/`
			}
		})} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
				box-sizing: border-box;
				overflow-x: hidden;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 100%;
				max-width: 720px;
				margin: auto;
				padding: 1em;
				box-sizing: border-box;
				color: rgb(var(--gray-dark));
			}
			.title {
        margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0 0;
			}
			.coffee-box {
				display: grid;
				grid-template-columns: 120px minmax(0, 1fr);
				align-items: center;
				gap: 1rem;
				width: 100%;
				margin-top: 1.1rem;
				padding: 0.2rem 0.85rem;
				border: 1px solid rgba(217, 164, 6, 0.55);
				border-radius: 8px;
				color: #3d2f00;
				background: #ffef75;
				text-decoration: none;
				box-sizing: border-box;
				box-shadow: 0 10px 24px rgba(61, 47, 0, 0.08);
				transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
			}
			.coffee-box:hover {
				border-color: rgba(166, 119, 0, 0.82);
				background: #ffe14f;
				transform: translateY(-1px);
			}
			.coffee-figure {
				width: 150px;
				aspect-ratio: 1;
				height: auto;
				object-fit: contain;
				object-position: center;
				border-radius: 6px;
				filter: drop-shadow(0 6px 10px rgba(61, 47, 0, 0.14));
			}
			.coffee-copy {
				display: flex;
				flex-direction: column;
				gap: 0.2rem;
				text-align: left;
				line-height: 1.35;

				b{
					font-size: 1.2rem;
					font-weight: 700;
				}
			}
			.coffee-copy strong {
				font-size: 0.98rem;
				font-weight: 700;
			}
			.coffee-copy span {
				font-size: 0.86rem;
				color: rgba(61, 47, 0, 0.78);
			}
			.coffee-action {
				display: inline;
				font-size: 0.9rem;
				font-weight: 700;
				text-decoration: underline;
				text-underline-offset: 4px;
				white-space: nowrap;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.edit-button {
				display: inline-flex;
				align-items: center;
        gap: 5px;
        justify-content:flex-end;
				color: rgb(var(--gray-dark));
				font-size: 0.9rem;
				font-weight: 500;
				transition: all 0.2s ease;
        // margin-top: 1rem;
			}
			.edit-button:hover {
				background: rgba(0, 0, 0, 0.08);
				border-color: rgba(0, 0, 0, 0.2);
				color: rgb(var(--black));
			}
			.edit-button svg {
				flex-shrink: 0;
			}
			@media (max-width: 520px) {
				.coffee-box {
					grid-template-columns: 80px minmax(0, 1fr);
					gap: 0.55rem;
					padding: 0.65rem;

					b{
						font-size: 1rem;
						line-height: 1;
					}
				}
				.coffee-figure {
					width: 85px;
				}
				.coffee-action {
					font-size: 0.82rem;
				}
			}
      article{


li{
  /* padding: 10px 0; */
  line-height: 1.5;
}
      }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{readTime && <span> · {readTime}</span>}
							{
								updatedDate && (
									<div class="last-updated-on">
										Última modificación el <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<a href="https://buymeacoffee.com/ndavidcastillo" class="coffee-box" target="_blank" rel="noopener noreferrer" aria-label="Invítame un café para seguir creando contenido">
							<img class="coffee-figure" src="/assets/cool_buymecoffe.png" alt="" loading="lazy" />
							<span class="coffee-copy">
								<b>¿Te gusto este contenido?</b>
								<span>Invítame un café, es la cortesía de un cabellero super elegante. <span class="coffee-action">clic aquí</span></span>
							</span>
						</a>
						<hr />
					</div>
					<slot />
          <hr/>
        <p>
        { tags && tags.map((tag)=>(
        <span> #{tag},</span>
        )) }
        </p>
					<a 
						href={`https://github.com/ndcastillo/ndavidcastillo/blob/main/src/content/blog/${postSlug}.md`}
						class="edit-button"
						target="_blank"
						rel="noopener noreferrer"
						title="Editar en GitHub"
					>
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
							<path d="m18.5 2.5 2 2L13 12l-4 1 1-4 7.5-7.5z"></path>
						</svg>
						Editar en GitHub
					</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
