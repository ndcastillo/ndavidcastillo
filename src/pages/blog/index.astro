---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import {readingTime} from '../../utils/readingTime'

const posts = (await getCollection('blog')).sort(
(a, b) => {
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
},
);

const monthsSpanish = ["Enero","Febrero","Marzo","Abril","Mayo","Junio","Julio","Agosto","Septiembre","Octubre","Noviembre","Diciembre"];

let listYear = {};

posts.forEach((item, index)=>{
  item.readingTime = readingTime(item.body,"es");
  let year = new Date(item.data.pubDate).getFullYear();
  let month = new Date(item.data.pubDate).getMonth();

  if(Object.keys(listYear).includes(String(year))){
    if(Object.keys(listYear[year]).includes(String(month))){
      listYear[String(year)][month].push(item);
    }else{
      listYear[String(year)][month] = [item];
    }
  }else{
    listYear[String(year)] = {
      [String(month)]: [item]
    }
  }
});

// Ordenar años de forma descendente
const sortedYears = Object.keys(listYear).sort((a, b) => Number(b) - Number(a));
---  

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.year-section {
				margin-bottom: 4rem;
			}
			.year-header {
				font-size: 2rem;
				font-weight: bold;
				color: rgb(var(--black));
				border-bottom: 2px solid rgb(var(--accent));
				display: flex;
				align-items: center;
				gap: 0.75rem;
			}
			.month-section {
				margin-bottom: 2.5rem;
			}
			.month-header {
				font-size: 1.5rem;
				font-weight: 600;
        font-style:italic;
				color: rgb(var(--black));
				margin-bottom: 1.5rem;
				display: flex;
				align-items: center;
				justify-content: flex-start;
				gap: 0.5rem;
			}
			.post-count {
				font-size: 0.9rem;
        font-style: normal;
				color: rgb(var(--black));
				padding: 0.3rem 0.85rem;
				border-radius: 20px;
				font-weight: 500;
			}
			ul {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: 100%;
			}
			ul li a {
				display: flex;
				flex-direction: row;
				gap: 1.5rem;
				text-decoration: none;
				transition: all 0.3s ease;
				padding: 1rem;
				border-radius: 12px;
				background: rgba(0, 0, 0, 0.01);
			}
			ul li a:hover {
				background: rgba(0, 0, 0, 0.03);
				transform: translateY(-2px);
			}
			.post-image {
				flex-shrink: 0;
				width: 280px;
				height: 180px;
				overflow: hidden;
				border-radius: 8px;
			}
			.post-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.3s ease;
			}
			ul li a:hover .post-image img {
				transform: scale(1.05);
			}
			.post-data {
				flex: 1;
				display: flex;
				flex-direction: column;
				padding: 0.5rem 0;
			}
			.post-title {
				font-size: 1.5rem;
				font-weight: 700;
				color: rgb(var(--black));
				line-height: 1.3;
				margin: 0;
				transition: color 0.2s ease;
			}
			ul li a:hover .post-title {
				color: rgb(var(--accent));
			}
			.post-date {
				font-size: 0.9rem;
				margin: 0;
			}
			.post-description {
				font-size: 1rem;
				line-height: 1.6;
				margin: 0;
			}
			.post-reading-time {
				font-size: 0.85rem;
				margin: 0;
				display: flex;
				align-items: center;
				gap: 0.3rem;
			}
			@media (max-width: 720px) {
				main {
					width: 100%;
					padding: 0 1rem;
				}
				.year-header {
					font-size: 1.5rem;
					align-items: flex-start;
					gap: 0.5rem;
				}
				.month-header {
          display:flex;
					font-size: 1.2rem;
					align-items: flex-start;
					gap: 0.5rem;
				}
				ul {
					gap: 1rem;
				}
				ul li a {
					flex-direction: column;
					gap: 1rem;
					padding: 0.75rem;
				}
				.post-image {
					width: 100%;
					height: 200px;
				}
				.post-title {
					font-size: 1.25rem;
				}
				.post-description {
					font-size: 0.95rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
    <main>
			{sortedYears.map((year) => {
				// Ordenar los meses de forma descendente (más reciente primero)
				const sortedMonths = Object.keys(listYear[year]).sort((a, b) => Number(b) - Number(a));
				const yearPostCount = sortedMonths.reduce((acc, month) => acc + listYear[year][month].length, 0);
				
				return (
					<div class="year-section">
						<h2 class="year-header">
							{year}
							<span class="post-count">{yearPostCount}</span>
						</h2>
						
						{sortedMonths.map((month) => {
							const monthPosts = listYear[year][month];
							return (
								<div class="month-section">
                  <h3 class="month-header">
                    <span class="category-months">{monthsSpanish[Number(month)]}</span>
										<span class="post-count">{monthPosts.length}</span>
									</h3>
									<ul>
										{monthPosts.map((post) => (
											<li>
												<a href={`/blog/${post.id}/`}>
													<div class="post-image">      
														{post.data.heroImage && (
															<Image 
																width={560} 
																height={360} 
																src={post.data.heroImage} 
																alt={post.data.title}
															/>
														)}
													</div>
													<div class="post-data">
														<h3 class="post-title">{post.data.title}</h3>
														<p class="post-date">
															<FormattedDate date={post.data.pubDate} />
														</p>
														<p class="post-description">{post.data.description}</p>
														<p class="post-reading-time">{post.readingTime}</p>
													</div>
												</a>
											</li>
										))}
									</ul>
								</div>
							);
						})}
					</div>
				);
			})}
		</main>
		<Footer />
	</body>
</html>
