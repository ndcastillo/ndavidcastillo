---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HomeOgImage from '../assets/blog-placeholder-1.jpg';
import { USER_WHATSAPP_URL, USER_PROFILE, SITE_AUTHOR, SITE_HOME_DESCRIPTION, SITE_TITLE, SITE_URL, USER_GITHUB, USER_TWITTER, USER_LINKEDIN, USER_EMAIL, USER_INSTAGRAM, USER_TIKTOK, USER_YOUTUBE } from '../consts';
import {readingTime} from '../utils/readingTime'

const posts = (await getCollection('blog', ({ data }) => {
	return data.draft !== true;
}))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 10)
	.map(post => ({
		...post,
		readingTime: readingTime(post.body, "es")
	}));

  const redes = {
    "GITHUB": "https://github.com/" + USER_GITHUB,
    "X":"https://x.com/" + USER_TWITTER,
    "LINKEDIN":"https://linkedin.com/in/" + USER_LINKEDIN,
    "INSTAGRAM":"https://instagram.com/" + USER_INSTAGRAM,
    "TIKTOK":"https://tiktok.com/@" + USER_TIKTOK,
    "YOUTUBE":"https://youtube.com/@" + USER_YOUTUBE
  } 
const email = `mailto:${USER_EMAIL}`;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_HOME_DESCRIPTION} image={HomeOgImage} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": SITE_AUTHOR,
			"url": SITE_URL,
			"description": SITE_HOME_DESCRIPTION,
			"potentialAction": {
				"@type": "SearchAction",
				"target": SITE_URL + "/search?q={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		})} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": SITE_AUTHOR,
			"url": SITE_URL,
			"description": SITE_HOME_DESCRIPTION,
			"sameAs": [
				redes["GITHUB"],
				redes["LINKEDIN"],
				redes["X"]
			]
		})} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "SiteNavigationElement",
					"name": "Posts",
					"url": SITE_URL + "/blog"
				},
				{
					"@type": "SiteNavigationElement",
					"name": "Acerca de mi",
					"url": SITE_URL + "/about"
				}
			]
		})} />
	</head>
	<body>
		<Header />
		<main>

			<!-- PERFIL -->
			<section class="profile">
				<img
					class="avatar"
					src={USER_PROFILE}
					alt={SITE_AUTHOR}
					width="120"
					height="120"
					fetchpriority="high"
				/>
				<div class="bio">
          <h1>{SITE_AUTHOR}</h1>
          <p class="role">Sitio Personal</p>

          <p class="description">
			Este es un espacio digital, donde comparto mis conocimientos y experiencias sobre el mundo de las tecnologias de la información y algo más. Aquí encontraras artículos, tutoriales y reflexiones de mi autoría.
					</p>
					<div class="contact">
            <a href={email} class="contact-link" aria-label="Enviar correo electrónico">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              {USER_EMAIL}
						</a>
					</div>
					<div class="social">
            <a href={redes.GITHUB} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
						</a>
            <a href={redes.X} target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						</a>
            <a href={redes.LINKEDIN} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						</a>
            <a href={redes.INSTAGRAM} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
						</a>
            <a href={redes.TIKTOK} target="_blank" rel="noopener noreferrer" aria-label="TikTok">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-.88-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43V7.56a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.05z"/></svg>
						</a>
            <a href={redes.YOUTUBE} target="_blank" rel="noopener noreferrer" aria-label="YouTube">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
						</a>
            <a href={USER_WHATSAPP_URL} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
						</a>
					</div>
				</div>
			</section>

			<hr />

			<!-- ÚLTIMOS POSTS -->
			<section class="recent-posts">
				<h2>Últimos Posts</h2>
				<ul>
					{posts.map((post) => (
						<li class={post.data.heroImage ? 'has-image' : 'no-image'}>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<div class="post-thumb">
										<Image
											width={480}
											height={300}
											densities={[1, 1.5, 2]}
											quality={90}
											src={post.data.heroImage}
											alt={post.data.title}
										/>
									</div>
								)}
								<div class="post-body">
									<div class="post-head">
										<span class="post-title">{post.data.title}</span>
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} /> · {post.readingTime}
										</span>
									</div>
									<p class="post-description">{post.data.description}</p>
								</div>
							</a>
						</li>
					))}
				</ul>

			</section>

        <p class="link-complete">
          <a href="/blog">Ver todos los posts</a>
        </p>


		</main>
		<Footer />
	</body>
</html>

<style>
	/* ── PERFIL ── */
	.link-complete {
		text-align: right;
	}
	main > hr {
		border: none;
		border-top: 1px solid rgb(var(--gray-light));
		margin: 2rem 0;
	}
	.profile {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.avatar {
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
	}
	.bio h1 {
		font-size: 1.953rem;
		margin-bottom: 0.2rem;
	}
	.role {
		font-size: 1rem;
		margin: 0;
		padding-bottom: 0.625rem;
	}
	.description {
		font-size: 1rem;
		margin-top: 0;
	}
	.contact {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin-bottom: 0.8rem;
	}
	.contact-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.9em;
		text-decoration: none;
  }
	.contact-link:hover {
		text-decoration: underline;
		text-decoration-style: dashed;
		text-underline-offset: 5px;
	}
	.social {
		display: flex;
		gap: 1rem;
	}
	.social a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		display: flex;
		align-items: center;
	}
	.social a:hover {
		color: rgb(var(--black));
	}

	/* ── ÚLTIMOS POSTS ── */
	.recent-posts h2 {
		font-size: 1.25em;
		margin-bottom: 1rem;
	}
	.recent-posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.recent-posts li {
		border-bottom: 1px solid rgb(var(--gray-light));
		padding: 0.75rem 0;
	}
	.recent-posts li:last-child {
		border-bottom: none;
	}
	.recent-posts a {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		gap: 1rem;
		text-decoration: none;
	}
	.recent-posts a:hover .post-title {
		text-decoration: underline;
		text-decoration-style: dashed;
		text-underline-offset: 5px;
	}
	.post-thumb {
		flex-shrink: 0;
		width: 120px;
		height: 75px;
		overflow: hidden;
		border-radius: 6px;
	}
	.post-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}
	.recent-posts a:hover .post-thumb img {
		transform: scale(1.05);
	}
	.post-body {
		flex: 1;
		min-width: 0;
	}
	.post-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}
	.post-title {
		flex: 1;
	}
	.post-date {
		color: rgb(var(--black));
		font-size: 0.85em;
		white-space: nowrap;
	}
	.post-description {
		margin: 0.3rem 0 0 0;
		font-size: 0.85em;
	}

	/* ── RESPONSIVE ── */
	@media (max-width: 720px) {
		.profile {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
		.contact {
			align-items: center;
		}
		.social {
			justify-content: center;
		}
		.recent-posts a {
			flex-direction: column;
			gap: 0.5rem;
		}
		.post-thumb {
			width: 100%;
			height: 160px;
		}
		.post-head {
			flex-direction: column;
			gap: 0.2rem;
		}
	}
</style>
