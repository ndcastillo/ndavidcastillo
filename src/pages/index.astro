---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": SITE_AUTHOR,
			"url": SITE_URL,
			"description": SITE_DESCRIPTION,
			"sameAs": [
        "https://github.com/" + USER_GITHUB,
				"https://x.com/" + USER_TWITTER,
				"https://linkedin.com/in/" + USER_LINKEDIN
			]
		})} />
	</head>
	<body>
		<Header />
		<main>

			<!-- PERFIL -->
			<section class="profile">
				<img
					class="avatar"
					src="/placeholder-avatar.jpg"
					alt="Foto de perfil"
					width="120"
					height="120"
				/>
				<div class="bio">
          <h1>{SITE_AUTHOR}</h1>
					<p class="role">Consultor TI - Aprendizaje Autónomo - Telecom</p>
          <p>
          Ingeniero en Electrónica y Telecomunicaciones con más de 4 años desarrollando soluciones de software para empresas de servicios, industria y retail. Especializado en integraciones ERP-Ecommerce, desarrollo de microservicios, pasarelas de pago y sistemas IoT. Experiencia liderando equipos técnicos y arquitecturas cloud en AWS, DigitalOcean y Cloudflare. Divulgador de Rust y ganador del mejor paper en IEEE ETCM 2024.          
					</p>
					<div class="contact">
						<a href="mailto:nestor.castillo@ieee.org" class="contact-link" title="Email">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
							tucorreo@ejemplo.com
						</a>
						<a href="https://wa.me/1234567890" class="contact-link" title="WhatsApp" target="_blank" rel="noopener noreferrer">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
							+12 345 678 90
						</a>
					</div>
					<div class="social">
            <a href="https://github.com/{USER_GITHUB}" target="_blank" rel="noopener noreferrer" title="GitHub">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
						</a>
            <a href="https://twitter.com/{USER_TWITTER}" target="_blank" rel="noopener noreferrer" title="X / Twitter">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
						</a>
            <a href="https://linkedin.com/in/{USER_LINKEDIN}" target="_blank" rel="noopener noreferrer" title="LinkedIn">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
						</a>
					</div>
				</div>
			</section>

			<hr />

			<!-- ÚLTIMOS POSTS -->
			<section class="recent-posts">
				<h2>Últimos Posts</h2>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
							<p class="post-description">{post.data.description}</p>
						</li>
					))}
				</ul>
			</section>

			<hr />

			<!-- FORMACIÓN Y LOGROS -->
			<section class="section-block">
				<h2>Formación y Logros</h2>
				<ul class="timeline">
					<li>
						<span class="year">2020</span>
						<div>
							<strong>Título universitario</strong>
							<p>Universidad Ejemplo · Ingeniería / Ciencias / etc.</p>
						</div>
					</li>
					<li>
						<span class="year">2022</span>
						<div>
							<strong>Maestría / Certificación</strong>
							<p>Institución Ejemplo · Área de especialización</p>
						</div>
					</li>
					<li>
						<span class="year">2024</span>
						<div>
							<strong>Logro destacado</strong>
							<p>Descripción breve del logro, premio o reconocimiento obtenido.</p>
						</div>
					</li>
				</ul>
			</section>

			<hr />

			<!-- EXPERIENCIA EN EMPRESAS -->
			<section class="section-block">
				<h2>Experiencia</h2>
				<ul class="companies">
					<li>
						<div class="company-header">
							<strong>Empresa A</strong>
							<span class="year-range">2021 – 2023</span>
						</div>
						<p class="company-role">Rol · Área</p>
						<p>Descripción breve de tu participación, responsabilidades y logros en esta empresa.</p>
					</li>
					<li>
						<div class="company-header">
							<strong>Empresa B</strong>
							<span class="year-range">2023 – Presente</span>
						</div>
						<p class="company-role">Rol · Área</p>
						<p>Descripción breve de tu participación, responsabilidades y logros en esta empresa.</p>
					</li>
				</ul>
			</section>

			<hr />

			<!-- PRODUCTOS -->
			<section class="section-block">
				<h2>Productos</h2>
				<ul class="products">
					<li>
						<strong>Nombre del Producto</strong>
						<p>Descripción breve de qué hace el producto, a quién va dirigido y cuál es su propuesta de valor.</p>
						<a href="#" target="_blank" rel="noopener noreferrer">Ver producto →</a>
					</li>
					<li>
						<strong>Nombre del Producto 2</strong>
						<p>Descripción breve de qué hace el producto, a quién va dirigido y cuál es su propuesta de valor.</p>
						<a href="#" target="_blank" rel="noopener noreferrer">Ver producto →</a>
					</li>
				</ul>
			</section>

			<hr />

			<!-- TESTIMONIOS -->
			<section class="section-block">
				<h2>Testimonios</h2>
				<ul class="testimonials">
					<li>
						<blockquote>
							"Texto del testimonio. Descripción de la experiencia de trabajo y el valor que aportaste."
						</blockquote>
						<p class="testimonial-author">— Nombre Persona, Cargo · Empresa</p>
					</li>
					<li>
						<blockquote>
							"Texto del testimonio. Descripción de la experiencia de trabajo y el valor que aportaste."
						</blockquote>
						<p class="testimonial-author">— Nombre Persona, Cargo · Empresa</p>
					</li>
					<li>
						<blockquote>
							"Texto del testimonio. Descripción de la experiencia de trabajo y el valor que aportaste."
						</blockquote>
						<p class="testimonial-author">— Nombre Persona, Cargo · Empresa</p>
					</li>
				</ul>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	/* ── PERFIL ── */
	.profile {
		display: flex;
		align-items: flex-start;
		gap: 2rem;
		margin-bottom: 2rem;
	}
	.avatar {
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
	}
	.bio h1 {
		font-size: 1.953em;
		margin-bottom: 0.2rem;
	}
	.role {
		color: rgb(var(--gray));
		font-size: 0.9em;
		margin-bottom: 0.8rem;
	}
	.contact {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin-bottom: 0.8rem;
	}
	.contact-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.9em;
		text-decoration: none;
	}
	.contact-link:hover {
		text-decoration: underline;
		text-decoration-style: dashed;
		text-underline-offset: 6px;
	}
	.social {
		display: flex;
		gap: 1rem;
	}
	.social a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		display: flex;
		align-items: center;
	}
	.social a:hover {
		color: rgb(var(--black));
	}

	/* ── ÚLTIMOS POSTS ── */
	.recent-posts h2,
	.section-block h2 {
		font-size: 1.25em;
		margin-bottom: 1rem;
	}
	.recent-posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.recent-posts li {
		border-bottom: 1px solid rgb(var(--gray-light));
		padding: 0.75rem 0;
	}
	.recent-posts li:last-child {
		border-bottom: none;
	}
	.recent-posts a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		text-decoration: none;
	}
	.recent-posts a:hover .post-title {
		text-decoration: underline;
		text-decoration-style: dashed;
		text-underline-offset: 8px;
	}
	.post-title {
		flex: 1;
	}
	.post-date {
		color: rgb(var(--black));
		font-size: 0.85em;
		white-space: nowrap;
	}
	.post-description {
		margin: 0.3rem 0 0 0;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}

	/* ── SECCIONES GENERALES ── */
	.section-block {
		margin: 0;
	}

	/* ── FORMACIÓN ── */
	.timeline {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
	}
	.timeline li {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
	}
	.timeline .year {
		font-size: 0.85em;
		color: rgb(var(--gray));
		white-space: nowrap;
		min-width: 2.5rem;
		padding-top: 0.15rem;
	}
	.timeline p {
		margin: 0.1rem 0 0 0;
		font-size: 0.9em;
		color: rgb(var(--gray));
	}

	/* ── EXPERIENCIA ── */
	.companies {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.4rem;
	}
	.company-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
	}
	.year-range {
		font-size: 0.85em;
		color: rgb(var(--gray));
		white-space: nowrap;
	}
	.company-role {
		font-size: 0.88em;
		color: rgb(var(--gray));
		margin: 0.1rem 0 0.3rem 0;
	}
	.companies p:last-child {
		margin: 0;
		font-size: 0.9em;
	}

	/* ── PRODUCTOS ── */
	.products {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.4rem;
	}
	.products p {
		margin: 0.2rem 0 0.3rem 0;
		font-size: 0.9em;
	}
	.products a {
		font-size: 0.88em;
	}

	/* ── TESTIMONIOS ── */
	.testimonials {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.8rem;
	}
	.testimonials blockquote {
		border-left: 3px solid rgb(var(--gray-light));
		padding-left: 1rem;
		margin: 0;
		font-size: 0.95em;
		font-style: italic;
		color: rgb(var(--gray-dark));
	}
	.testimonial-author {
		margin: 0.4rem 0 0 1rem;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}

	/* ── RESPONSIVE ── */
	@media (max-width: 480px) {
		.profile {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
		.contact {
			align-items: center;
		}
		.social {
			justify-content: center;
		}
		.recent-posts a {
			flex-direction: column;
			gap: 0.2rem;
		}
		.company-header {
			flex-direction: column;
			gap: 0.1rem;
		}
	}
</style>
